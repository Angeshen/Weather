# Kalshi API Credentials
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=C:\Users\CPecoraro\kalshi-key.pem

# Trading Mode: "paper" or "live"
TRADING_MODE=paper

# Bankroll & Risk
INITIAL_BANKROLL=5000
MAX_TRADE_SIZE=75
DAILY_LOSS_LIMIT=250
MAX_CONCURRENT_TRADES=5
MIN_EDGE_THRESHOLD=0.05
KELLY_FRACTION=0.15

# Scan interval in seconds
SCAN_INTERVAL_SECONDS=300

# Telegram Notifications (optional)
# 1. Message @BotFather on Telegram, send /newbot, get your token
# 2. Message your bot, then visit https://api.telegram.org/bot<TOKEN>/getUpdates to get chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_DAILY_SUMMARY_HOUR=22
